Bootstrap: docker
From: nvidia/cuda:12.2.2-cudnn8-runtime-ubuntu22.04

# ============================================================================
# aivc-train.def — Apptainer definition for AIVC v1.1 training on MareNostrum5
#
# Target GPU:    NVIDIA H100 SXM5 64GB (sm_90, CUDA 12.x)
# Base image:    nvidia/cuda:12.2.2-cudnn8-runtime — matches MN5 driver stack
# PyTorch:       2.4.1+cu121 (wheels prebuilt for CUDA 12.1, forward-compat w/ 12.2)
# PyG:           2.7.0 from index-url with CUDA 12.1 wheels
#
# BUILD (on login node with fakeroot or on a build host):
#   apptainer build aivc-train.sif containers/aivc-train.def
#
# VERIFY inside container:
#   apptainer exec --nv aivc-train.sif python -c \
#     "import torch; print(torch.__version__, torch.cuda.is_available(), \
#      torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'cpu')"
#
# RATIONALE:
#   * CUDA 12.2 runtime: closest to MN5 driver stack (check with `nvidia-smi`
#     on a compute node via `srun --gres=gpu:1 -p acc_debug nvidia-smi`).
#   * BF16 + TF32: H100 native — no GradScaler needed (autocast bfloat16).
#   * torch==2.4.1: torch.compile is mature; reduce-overhead mode works.
#   * Pinned numpy<2: compatibility with torch-geometric and scanpy.
#   * All python deps installed into the system python — no venv — so
#     `python scripts/train_hpc.py ...` works directly via `apptainer exec`.
#
# KNOWN CAVEAT:
#   Compute nodes on MareNostrum5 have NO internet. The `%post` section runs
#   at BUILD time (login node or offline build host), not at container launch.
#   If the login node itself cannot reach pypi/github, build elsewhere and
#   scp the .sif to /gpfs/projects/<groupid>/aivc/containers/.
# ============================================================================

%labels
    Maintainer  Ash Khan <kinga@quriegen.com>
    Version     1.1.0
    Purpose     AIVC v1.1 H100 training (Neumann propagation sweep)
    Target      MareNostrum5 acc_bscls partition

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export DEBIAN_FRONTEND=noninteractive
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export PIP_NO_CACHE_DIR=1
    # Force MLflow to file backend — no HTTP on compute nodes
    export MLFLOW_TRACKING_URI="file:/mlruns"
    # Torch Inductor cache path — must be writable on compute nodes
    export TORCHINDUCTOR_CACHE_DIR=/tmp/torchinductor_cache
    export CUDA_MODULE_LOADING=LAZY
    # Disable HF telemetry (just in case any transitive dep phones home)
    export HF_HUB_OFFLINE=1
    export TRANSFORMERS_OFFLINE=1

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # ── System packages ────────────────────────────────────────────────────
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev python3-venv \
        git curl ca-certificates build-essential \
        libhdf5-dev pkg-config \
        libopenblas-dev liblapack-dev \
        libxml2 \
        && rm -rf /var/lib/apt/lists/*
    ln -sf /usr/bin/python3 /usr/bin/python

    python -m pip install --upgrade pip setuptools wheel

    # ── Pin numpy BEFORE torch ─────────────────────────────────────────────
    pip install "numpy>=1.26,<2.0"

    # ── PyTorch (CUDA 12.1 wheels — forward-compatible with 12.2 runtime) ──
    pip install \
        --index-url https://download.pytorch.org/whl/cu121 \
        torch==2.4.1 torchvision==0.19.1

    # ── PyTorch-Geometric (matches torch 2.4 + cu121) ──────────────────────
    pip install torch-geometric==2.7.0

    # Optional native scatter/sparse/cluster/spline wheels for PyG
    # (only install if the prebuilt wheel exists for this torch+cuda combo)
    pip install \
        -f https://data.pyg.org/whl/torch-2.4.1+cu121.html \
        torch-scatter torch-sparse || true

    # ── Core science stack ─────────────────────────────────────────────────
    pip install \
        scanpy==1.11.5 \
        anndata \
        muon \
        scipy \
        pandas \
        scikit-learn \
        matplotlib \
        seaborn \
        tqdm \
        pyarrow

    # ── AIVC-specific ──────────────────────────────────────────────────────
    pip install \
        "POT>=0.9.0" \
        mlflow \
        tensorboard \
        h5py \
        pyyaml \
        "pydantic>=2.0" \
        "fastapi>=0.110" \
        "uvicorn[standard]"

    # ── Create writable dirs (before apptainer binds override) ─────────────
    mkdir -p /workspace /data /checkpoints /outputs /mlruns /tmp/torchinductor_cache
    chmod -R a+rwX /mlruns /tmp/torchinductor_cache

%test
    # Runs at `apptainer build`-time. Any non-zero exit aborts the build.
    python -c "import sys; print('Python:', sys.version)"
    python -c "import torch; print('Torch:', torch.__version__); print('CUDA built:', torch.version.cuda)"
    python -c "import torch_geometric; print('PyG:', torch_geometric.__version__)"
    python -c "import scanpy, anndata, muon, numpy, pandas; \
               print('scanpy:', scanpy.__version__); \
               print('numpy:', numpy.__version__)"
    python -c "import ot; print('POT:', ot.__version__)"
    python -c "import mlflow; print('MLflow:', mlflow.__version__)"

%runscript
    exec python "$@"

%help
    AIVC v1.1 training container (H100-ready).

    Usage inside SLURM job (see scripts/train_v11.sbatch):

      apptainer exec --nv aivc-train.sif \
          python /workspace/scripts/train_hpc.py \
              --data-dir /data \
              --checkpoint-dir /checkpoints \
              --output-dir /outputs \
              --sweep-index $SLURM_ARRAY_TASK_ID \
              --resume

    Interactive debugging:

      apptainer shell --nv aivc-train.sif

    Verify CUDA inside:

      apptainer exec --nv aivc-train.sif nvidia-smi
